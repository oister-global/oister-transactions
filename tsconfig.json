{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "app/store/services/buildCustomFetchBaseQuery.js",
    "app/store/services/authApi.js",
    "app/components/ButtonsGroup.jsx",
    "public/svg.jsx",
    "app/layout.jsx",
    "app/transactions/page.jsx",
    "app/transactions/components/Buttons.jsx",
    "app/store/StoreProvider.jsx",
    "app/store/store.js",
    "app/store/services/transactionsApi.js",
    "app/login/page.jsx",
    "app/login/components/LoginAuthPanel.jsx",
    "app/components/VideoComponent.jsx",
    "app/components/TransactionCard.jsx",
    "app/components/SecondaryButton.jsx",
    "app/components/PrimaryButton.jsx",
    "app/components/OTPInput.jsx",
    "app/components/Modal.jsx",
    "app/components/MainLayout.jsx",
    "app/components/Header.jsx",
    "app/components/Footer.jsx",
    "app/components/CustomList.jsx",
    "app/components/ComponentWrapper.jsx",
    "app/login/components/EmailInputAndButton.jsx"
  ],
  "exclude": ["node_modules"]
}
